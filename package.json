{
    "name": "pets-roll",
    "description": "A Phaser 3 TypeScript template using Vite.",
    "version": "1.4.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/phaserjs/template-vite-ts.git"
    },
    "author": "Phaser Studio <support@phaser.io> (https://phaser.io/)",
    "license": "MIT",
    "licenseUrl": "http://www.opensource.org/licenses/mit-license.php",
    "bugs": {
        "url": "https://github.com/phaserjs/template-vite-ts/issues"
    },
    "homepage": "https://github.com/phaserjs/template-vite-ts#readme",
    "scripts": {
        "dev": "node log.js dev & vite --config vite/config.dev.mjs",
        "build": "node log.js build & vite build --config vite/config.prod.mjs",
        "dev-nolog": "vite --config vite/config.dev.mjs",
        "build-nolog": "vite build --config vite/config.prod.mjs",
        "build:poki": "cross-env VITE_PLATFORM=poki vite build --config vite/config.prod.mjs",
        "build:crazygames": "cross-env VITE_PLATFORM=crazygames vite build --config vite/config.prod.mjs",
        "build:gamedist": "cross-env VITE_PLATFORM=gamedist vite build --config vite/config.prod.mjs",
        "build:yandex": "cross-env VITE_PLATFORM=yandex vite build --config vite/config.prod.mjs",
        "build:gamemonetize": "cross-env VITE_PLATFORM=gamemonetize vite build --config vite/config.prod.mjs",
        "build:gamepix": "cross-env VITE_PLATFORM=gamepix vite build --config vite/config.prod.mjs",
        "build:addictinggames": "cross-env VITE_PLATFORM=addictinggames vite build --config vite/config.prod.mjs",
        "build:itchio": "cross-env VITE_PLATFORM=itchio vite build --config vite/config.prod.mjs",
        "build:all": "npm run build:poki && npm run build:crazygames && npm run build:gamedist && npm run build:yandex && npm run build:gamemonetize && npm run build:gamepix && npm run build:addictinggames && npm run build:itchio",
        "gen-sfx": "node scripts/generate-grade-sfx.mjs"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "ffmpeg-static": "^5.3.0",
        "sharp": "^0.34.5",
        "typescript": "~5.7.2",
        "vite": "^6.3.1"
    },
    "dependencies": {
        "exceljs": "^4.4.0",
        "phaser": "^3.90.0",
        "terser": "^5.39.0"
    }
}
